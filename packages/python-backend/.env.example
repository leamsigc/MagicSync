# MagicSync Python Backend Environment
# Copy this file to .env in packages/python-backend/

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file to .env:
#    cp .env-example .env
#
# 2. Ollama (optional, for local LLM):
#    - Install: https://ollama.com/
#    - Start: ollama serve
#    - Pull models: ollama pull llama3.2
#                   ollama pull nomic-embed-text
#
# 3. LangSmith (optional, for tracing):
#    - Get key: https://smith.langchain.com/
#
# =============================================================================
# APP CONFIG
# =============================================================================
APP_NAME=MagicSync AI Backend
APP_VERSION=0.1.0
DEBUG=false

# =============================================================================
# CORS - Frontend URLs
# =============================================================================
# For local dev: ["http://localhost:3000"]
# For Docker: ["http://localhost:3000","http://site:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# =============================================================================
# BETTER AUTH (Nuxt server for session validation)
# =============================================================================
# For local dev: http://localhost:3000
# For Docker: http://site:3000
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# OLLAMA (Local LLM)
# =============================================================================
# Install from https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# LANGSMITH (Optional, for tracing)
# =============================================================================
# Get from https://smith.langchain.com/
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=magicsync-ai