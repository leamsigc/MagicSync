# MagicSync Python Backend Environment
# Copy this file to .env in packages/python-backend/

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file to .env:
#    cp .env-example .env
#
# 2. Ollama (optional, for local LLM):
#    - Install: https://ollama.com/
#    - Start: ollama serve
#    - Pull models: ollama pull qwen3.5
#                   ollama pull nomic-embed-text
#
# 3. LangSmith (optional, for tracing):
#    - Get key: https://smith.langchain.com/
#
# 4. LLM JWT Secret (REQUIRED):
#    - MUST match NUXT_LLM_JWT_SECRET in root .env
#    - Generate: openssl rand -hex 32
#
# =============================================================================
# APP CONFIG
# =============================================================================
APP_NAME=MagicSync AI Backend
APP_VERSION=0.1.0
DEBUG=false

# =============================================================================
# CORS - Frontend URLs
# =============================================================================
# For local dev: ["http://localhost:3000"]
# For Docker: ["http://localhost:3000","http://site:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# =============================================================================
# JWT AUTH (Service-to-service communication with Nuxt)
# =============================================================================
# IMPORTANT: MUST MATCH NUXT_LLM_JWT_SECRET IN ROOT .env
# Used to validate JWT tokens from Nuxt containing user info and LLM config
# Generate: openssl rand -hex 32
LLM_JWT_SECRET=<generate-openssl-rand-hex-32>

# =============================================================================
# BETTER AUTH (Nuxt server - kept for backward compatibility)
# =============================================================================
# For local dev: http://localhost:3000
# For Docker: http://site:3000
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# OLLAMA (Platform default LLM - used when user has no custom config)
# =============================================================================
# Install from https://ollama.com/
# Models used by default when no user-specific config exists
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3.5
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# LANGSMITH (Optional, for tracing)
# =============================================================================
# Get from https://smith.langchain.com/
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=magicsync-ai

# =============================================================================
# LLM PROVIDER NOTES
# =============================================================================
# The backend uses LiteLLM which supports multiple providers:
# - Ollama (local, default): ollama/qwen3.5
# - OpenAI: gpt-4o, gpt-4o-mini
# - Anthropic: claude-3-5-sonnet, claude-3-haiku
# - OpenRouter: openrouter/openai/gpt-4o (100+ models)
#
# Users can configure their own provider/model via the settings page.
# API keys for cloud providers are passed via JWT from Nuxt.

# =============================================================================
# FEATURE FLAGS
# =============================================================================
KNOWLEDGE_BASE_ENABLED=true
PII_REDACTION_ENABLED=false
SANDBOX_ENABLED=false
TOOL_REGISTRY_ENABLED=true

# =============================================================================
# TOKEN MANAGEMENT
# =============================================================================
LLM_CONTEXT_WINDOW=128000
MAX_DEEP_ROUNDS=50
MAX_SUB_AGENT_ROUNDS=15

# =============================================================================
# MCP SERVERS (Model Context Protocol)
# =============================================================================
# Format: JSON array or comma-separated
# JSON: '[{"name": "github", "command": "npx", "args": ["-y", "@modelcontextprotocol/server-github"]}]'
# Simple: 'github:npx:-y:@modelcontextprotocol/server-github'
MCP_SERVERS=
