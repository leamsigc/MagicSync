# MagicSync Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file to .env:
#    cp .env-example .env
#
# 2. Copy python backend env:
#    cp packages/python-backend/.env.example packages/python-backend/.env
#
# 3. For Docker development with local db:
#    - Generate JWT key: openssl rand -hex 32
#    - Generate SQLD_AUTH_JWT_KEY: openssl rand -hex 32
#    - Set JWT and SQLD_AUTH_JWT_KEY to those values
#
# 4. Generate secrets:
#    - SESSION_PASSWORD: openssl rand -hex 32
#    - BETTER_AUTH_SECRET: openssl rand -hex 32
#
# =============================================================================
# DATABASE (Turso / libsql)
# =============================================================================
# Option A: Docker local database (recommended for dev)
# JWT=<your-jwt-key>                    # Generate: openssl rand -hex 32
# SQLD_AUTH_JWT_KEY=<your-sql-key>      # Generate: openssl rand -hex 32
# NUXT_TURSO_DATABASE_URL=http://localhost:8080
# NUXT_TURSO_AUTH_TOKEN=<your-jwt-key>

# Option B: Turso cloud
# Get from https://turso.tech/
# NUXT_TURSO_DATABASE_URL=<turso-database-url>
# NUXT_TURSO_AUTH_TOKEN=<turso-auth-token>

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NUXT_HOST=0.0.0.0
NUXT_APP_URL=http://localhost:3000
NUXT_BASE_URL=http://localhost:3000
NUXT_SESSION_PASSWORD=<generate-openssl-rand-hex-32>

# =============================================================================
# BETTER AUTH (https://better-auth.com/)
# =============================================================================
NUXT_BETTER_AUTH_URL=http://localhost:3000
NUXT_BETTER_AUTH_SECRET=<generate-openssl-rand-hex-32>
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=<generate-openssl-rand-hex-32>

# =============================================================================
# PYTHON BACKEND (FastAPI / RAG / AI)
# =============================================================================
# Backend URL from Nuxt's perspective
NUXT_PYTHON_API_URL=http://localhost:8000

# =============================================================================
# EMAIL (https://www.mailgun.com/)
# =============================================================================
NUXT_MAILGUN_API_KEY=<mailgun-api-key>
NUXT_MAILGUN_DOMAIN=<mailgun-domain>
NUXT_MAIL_FROM_EMAIL=noreply@<your-domain>

# =============================================================================
# FILE STORAGE
# =============================================================================
NUXT_FILE_STORAGE_MOUNT=./upload/files

# =============================================================================
# AI SERVICES
# =============================================================================
# OpenAI (https://platform.openai.com/api-keys)
NUXT_OPENAI_API_KEY=<openai-api-key>

# Pexels (https://www.pexels.com/api/)
NUXT_PEXELS_API_KEY=<pexels-api-key>

# Google Generative AI (https://aistudio.google.com/app/api-keys)
NUXT_GOOGLE_GENERATIVE_AI_API_KEY=<google-generative-ai-api-key>

# =============================================================================
# SOCIAL MEDIA OAUTH - SETUP AT RESPECTIVE DEV PORTALS
# =============================================================================
# Google (https://console.developers.google.com/)
NUXT_GOOGLE_CLIENT_ID=<google-client-id>
NUXT_GOOGLE_CLIENT_SECRET=<google-client-secret>

# Facebook (https://developers.facebook.com/)
NUXT_FACEBOOK_CLIENT_ID=<facebook-client-id>
NUXT_FACEBOOK_CLIENT_SECRET=<facebook-client-secret>
NUXT_FACEBOOK_CONFIG_ID=<facebook-config-id>

# TikTok (https://developers.tiktok.com/)
NUXT_TIKTOK_CLIENT_ID=<tiktok-client-id>
NUXT_TIKTOK_CLIENT_SECRET=<tiktok-client-secret>

# Twitter / X (https://developer.twitter.com/)
NUXT_TWITTER_CLIENT_ID=<twitter-client-id>
NUXT_TWITTER_CLIENT_SECRET=<twitter-client-secret>

# LinkedIn (https://developer.linkedin.com/)
NUXT_LINKEDIN_CLIENT_ID=<linkedin-client-id>
NUXT_LINKEDIN_CLIENT_SECRET=<linkedin-client-secret>

# GitHub (https://github.com/settings/developers)
NUXT_GITHUB_CLIENT_ID=<github-client-id>
NUXT_GITHUB_CLIENT_SECRET=<github-client-secret>

# Discord (https://discord.com/developers/applications)
NUXT_DISCORD_CLIENT_ID=<discord-client-id>
NUXT_DISCORD_CLIENT_SECRET=<discord-client-secret>

# Reddit (https://www.reddit.com/prefs/apps)
NUXT_REDDIT_CLIENT_ID=<reddit-client-id>
NUXT_REDDIT_CLIENT_SECRET=<reddit-client-secret>

# Dribbble (https://developer.dribbble.com/)
NUXT_DRIBBBLE_CLIENT_ID=<dribbble-client-id>
NUXT_DRIBBBLE_CLIENT_SECRET=<dribbble-client-secret>

# YouTube (https://console.developers.google.com/)
NUXT_YOUTUBE_CLIENT_ID=<youtube-client-id>
NUXT_YOUTUBE_CLIENT_SECRET=<youtube-client-secret>

# Threads (Meta, via https://developers.facebook.com/)
NUXT_THREADS_CLIENT_ID=<threads-client-id>
NUXT_THREADS_CLIENT_SECRET=<threads-client-secret>

# Instagram (Meta, via https://developers.facebook.com/)
NUXT_INSTAGRAM_CLIENT_ID=<instagram-client-id>
NUXT_INSTAGRAM_CLIENT_SECRET=<instagram-client-secret>
NUXT_INSTAGRAM_CONFIG_ID=<instagram-config-id>

# WordPress (https://developer.wordpress.com/)
NUXT_WORDPRESS_CLIENT_ID=<wordpress-client-id>
NUXT_WORDPRESS_CLIENT_SECRET=<wordpress-client-secret>