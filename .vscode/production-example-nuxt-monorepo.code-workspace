{
	"folders": [
		{
			"path": ".."
		}
	],
	"settings": {
		"files.associations": {
			"*.css": "tailwindcss"
		},
		"tailwindCSS.classAttributes": [
			"class",
			"ui"
		],
		"js/ts.tsdk.path": "node_modules/typescript/lib"
	},
	"files.watcherExclude": {
		"**/node_modules": true,
		"**/node_modules/**": true,
		"**/node_modules/*/**": true,
		"**/node_modules/*/*/**": true
	}
}